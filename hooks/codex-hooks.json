{
  "description": "Codex plugin hooks for footnote context injection, safety gates, and target loops",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/graph-write-protect.sh",
            "statusMessage": "checking fno state surfaces"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/worktree-write-protect.sh",
            "statusMessage": "checking worktree location"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/worktree-harness-guard.sh",
            "statusMessage": "checking worktree harness ownership"
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/git-protection.py",
            "statusMessage": "checking git guardrails"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/inside-leg-report.sh working"
          },
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/born-with-why-offer-inject.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/target-stop-hook.sh"
          },
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/inside-leg-report.sh done"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/context-monitor.js"
          },
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/claim-heartbeat.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/target-subagent-guard.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/target-subagent-guard.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/save-session.py"
          },
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/arm-handoff-precompact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/target-postcompact-reinject.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "env FNO_PLATFORM=codex ${PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
