<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.user.autocorrect-watcher - 15-minute S0 watcher.
  Installed to ~/Library/LaunchAgents/ by scripts/install-autocorrect-cron.sh.
  Tokens {{...}} are substituted by the installer.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.autocorrect-watcher</string>
    <key>ProgramArguments</key>
    <array>
        <string>{{WATCHER_SCRIPT}}</string>
    </array>
    <key>StartInterval</key>
    <integer>900</integer>
    <key>StandardOutPath</key>
    <string>{{LOG_DIR}}/autocorrect-watcher.log</string>
    <key>StandardErrorPath</key>
    <string>{{LOG_DIR}}/autocorrect-watcher.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>{{HOME}}</string>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
